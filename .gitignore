# PyInstaller
#  Typically Python apps with PyInstaller are built into an executable.
#  The spec file and build/ directory are usually not needed in the repo.
#  We keep dist/flip_clock.exe as requested.
build/
*.spec

# Ignore everything in dist/ except flip_clock.exe
dist/*
!dist/flip_clock.exe

